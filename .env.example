# ── LLM Provider ──────────────────────────────
LLM_PROVIDER=openai
MODEL_NAME=gpt-4o

# ── Embedding Provider ────────────────────────
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# ── API Keys (añade solo las que uses) ────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── Paths ─────────────────────────────────────
DATA_DIR=data/
VECTORSTORE_DIR=models/vectorstores/

# ── Chunking ──────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── Monitoring ──────────────────────────────────

LANGCHAIN_TRACING_V2=
LANGCHAIN_ENDPOINT=
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=